TG_BOT_TOKEN=your_bot_token_here
TG_GROUP_ID=-100123456789
MAX_PHONE=+79990000000
MAX_DEVICE_ID=my_bridge_device
MAX_SESSION_DIR=pymax
MAX_SESSION_NAME=session.db

# Do not keep MAX_SMS_CODE in .env after auth.
# For Docker first login, write the fresh code to data/.max_sms_code instead:
#   echo 123456 > data/.max_sms_code

# Startup sync: create all topics, backfill only recent dialogs in background.
STARTUP_BACKFILL_ENABLED=true
STARTUP_BACKFILL_CHATS_LIMIT=10
STARTUP_BACKFILL_MESSAGES_PER_CHAT=10
